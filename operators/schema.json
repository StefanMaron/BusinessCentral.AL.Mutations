{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AL Mutation Operator File",
  "description": "Schema for AL mutation operator definitions (tree-sitter AST based)",
  "type": "object",
  "required": ["operators"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "operators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/operator"
      }
    }
  },
  "definitions": {
    "operator": {
      "type": "object",
      "required": ["id", "name", "category", "node_type"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique kebab-case identifier for this operator"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name for this operator"
        },
        "category": {
          "type": "string",
          "enum": [
            "relational",
            "arithmetic",
            "logical",
            "boolean",
            "statement-removal",
            "boundary",
            "control-flow",
            "bc-specific"
          ],
          "description": "Category for grouping and filtering operators"
        },
        "node_type": {
          "type": "string",
          "minLength": 1,
          "description": "Tree-sitter node type to match (e.g. comparison_expression, call_expression)"
        },
        "operator_token": {
          "type": "string",
          "description": "The operator token text to match within the node (e.g. '>', '+')"
        },
        "identifier": {
          "type": "string",
          "description": "Method/function name to match for call_expression nodes"
        },
        "argument_match": {
          "type": "string",
          "description": "Argument text to match (e.g. 'true' for .Modify(true))"
        },
        "replacement": {
          "type": ["string", "null"],
          "description": "Token to substitute. null means comment out the entire statement line."
        }
      }
    }
  }
}
